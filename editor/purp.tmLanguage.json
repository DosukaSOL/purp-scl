{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Purp",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#template-strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#solana-keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#attributes" },
    { "include": "#constants" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.purp",
          "match": "//.*$"
        },
        {
          "name": "comment.line.documentation.purp",
          "match": "///.*$"
        },
        {
          "name": "comment.block.purp",
          "begin": "/\\*",
          "end": "\\*/",
          "patterns": [{ "include": "#comments" }]
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.purp",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.purp",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.purp",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.purp",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "template-strings": {
      "patterns": [
        {
          "name": "string.template.purp",
          "begin": "`",
          "end": "`",
          "patterns": [
            {
              "name": "meta.template.expression.purp",
              "begin": "\\$\\{",
              "end": "\\}",
              "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin.purp" } },
              "endCaptures": { "0": { "name": "punctuation.definition.template-expression.end.purp" } },
              "patterns": [
                { "include": "$self" }
              ]
            },
            {
              "name": "constant.character.escape.purp",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.purp",
          "match": "\\b0[xX][0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.float.purp",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.purp",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.purp",
          "match": "\\b(if|else|match|for|while|loop|break|continue|return|in)\\b"
        },
        {
          "name": "keyword.declaration.purp",
          "match": "\\b(program|instruction|account|struct|enum|fn|trait|impl|type|event|error|const|let|mut|pub|use|module|import|from|as|test|client|frontend|config)\\b"
        },
        {
          "name": "keyword.operator.purp",
          "match": "\\b(async|await|try|catch|throw|assert|require)\\b"
        },
        {
          "name": "keyword.other.purp",
          "match": "\\b(self|super|deploy|transaction|wallet)\\b"
        }
      ]
    },
    "solana-keywords": {
      "patterns": [
        {
          "name": "keyword.solana.purp",
          "match": "\\b(signer|init|seeds|bump|pda|cpi|token|mint|nft|cnft|transfer|mint_to|burn|close_account|payer|space|has_one|close|emit|lamports|sol)\\b"
        },
        {
          "name": "support.type.solana.purp",
          "match": "\\b(Pubkey|Signer|SystemProgram|TokenProgram|Clock|Rent|TokenAccount|Mint|AssociatedToken)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.purp",
          "match": "\\b(u8|u16|u32|u64|u128|i8|i16|i32|i64|i128|f32|f64|bool|string|pubkey|bytes)\\b"
        },
        {
          "name": "storage.type.generic.purp",
          "match": "\\b(Vec|Option|Result|Map|Set|String)\\b"
        },
        {
          "name": "entity.name.type.purp",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.purp",
          "match": "\\b([a-z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.purp",
          "match": "(\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|=)"
        },
        {
          "name": "keyword.operator.comparison.purp",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.logical.purp",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.bitwise.purp",
          "match": "(<<|>>|&|\\||\\^)"
        },
        {
          "name": "keyword.operator.arithmetic.purp",
          "match": "(\\+|-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.arrow.purp",
          "match": "(->|=>)"
        },
        {
          "name": "keyword.operator.range.purp",
          "match": "(\\.\\.\\.|\\.\\.|\\.\\.=)"
        },
        {
          "name": "keyword.operator.optional.purp",
          "match": "(\\?\\.)"
        }
      ]
    },
    "attributes": {
      "patterns": [
        {
          "name": "meta.attribute.purp",
          "match": "#\\[([^\\]]*)\\]",
          "captures": {
            "1": { "name": "entity.other.attribute-name.purp" }
          }
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.purp",
          "match": "\\b(true|false|null|none|some)\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.purp",
          "match": "[{};:,.]"
        },
        {
          "name": "punctuation.bracket.purp",
          "match": "[()\\[\\]]"
        }
      ]
    }
  },
  "scopeName": "source.purp"
}
